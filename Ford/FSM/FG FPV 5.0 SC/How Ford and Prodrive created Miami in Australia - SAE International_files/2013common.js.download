function doOvrMnuDecide(theopener,thetitle) {
if (document.getElementById('ovrmnu-' + theopener + '-opener').className == 'dt-buy-opener') {
for (var i = 1; i < 10; i++) {
changeClass('ovrmnu-' + i + '-opener','dt-buy-opener');
}
doOvrMnu(theopener,thetitle);
} else {
closeOvrMnu(theopener);
}
}

function doOvrMnu(theopener,thetitle) {
updateFieldText('ovrmnu-heading',thetitle);
updateFieldWithSource('ovrmnu-content','ovrmu-' + theopener + '-content');
displayItem('ovrmnu-wrapper');
changeClass('ovrmnu-' + theopener + '-opener','dt-buy-closer');
document.getElementById('ovrmnu-close').href = "javascript:closeOvrMnu(" + theopener + ");";
document.getElementById('ovrmnu-close').title = "Close " + thetitle + " Menu";
}

function closeOvrMnu(theopener) {
updateFieldText('ovrmnu-heading','');
updateFieldWithSource('ovrmnu-content','');
hideItem('ovrmnu-wrapper');
changeClass('ovrmnu-' + theopener + '-opener','dt-buy-opener');
}




/* DESIGN FUNCS */


function slidesCount(thetype,theitem) {
var thecount = 0;
for (var i = 1; i < 101; i++) {
if (document.getElementById(thetype + '-' + theitem + '-items-' + i) != null) {thecount = i;}
}
if (thetype == 'sld') {
if (theitem > 1299) {
thecount = Math.ceil(thecount / 10);
} else if (theitem > 999) {
thecount = Math.ceil(thecount / 5);
} else if (theitem < 200) {
thecount = Math.ceil(thecount / 3);
} else {
thecount = Math.ceil(thecount / 4);
}
}
return thecount;
}

function smplNav(theact,theitem) {
var themax = slidesCount('smpl',theitem);
var theheight = 345;
var themove = -1;if (theact == 'back') {themove = 1;}
var theslot = document.getElementById('smpl' + '-' + theitem + '-items').style.top;theslot = theslot.replace('px','');theslot = Number(theslot) / theheight;
theslot = themove + theslot;
if (theslot > 0) {theslot = 1;} else {
if (theslot <= (themax * -1)) {} else {
document.getElementById('smpl' + '-' + theitem + '-items').style.top = (theheight * theslot) + 'px';
}
}
if ((theslot + 1 > 0)) {changeClass('smpl' + '-' + theitem + '-back','dimmed');} else {changeClass('smpl' + '-' + theitem + '-back','');}
if ((theslot - 1) <= (themax * -1)) {changeClass('smpl' + '-' + theitem + '-next','dimmed');} else {changeClass('smpl' + '-' + theitem + '-next','');}
if (themax < 2) {changeClass('smpl' + '-' + theitem + '-back','dimmed'); changeClass('smpl' + '-' + theitem + '-next','dimmed');}
}


