if (theitem > 99 && theitem < 1000) {theheight = 342; themax = Math.ceil(themax / 2);} else if (theitem > 1299) {theheight = 482; Math.ceil(themax / 10);} else if (theitem > 999) {theheight = 241; Math.ceil(themax / 5);}
var themove = -1;if (theact == 'back') {themove = 1;}
var theslot = document.getElementById('sld' + '-' + theitem + '-items').style.top;theslot = theslot.replace('px','');theslot = Number(theslot) / theheight;
theslot = themove + theslot;
if (theslot > 0) {theslot = 1;} else {
if (theslot <= (themax * -1)) {} else {
document.getElementById('sld' + '-' + theitem + '-items').style.top = (theheight * theslot) + 'px';
}
}
if ((theslot + 1 > 0)) {changeClass('sld' + '-' + theitem + '-back','dimmed');} else {changeClass('sld' + '-' + theitem + '-back','');}
if ((theslot - 1) <= (themax * -1)) {changeClass('sld' + '-' + theitem + '-next','dimmed');} else {changeClass('sld' + '-' + theitem + '-next','');}
if (themax < 2) {changeClass('sld' + '-' + theitem + '-back','dimmed'); changeClass('sld' + '-' + theitem + '-next','dimmed');}
}

