if ((theslot + 1 > 0)) {changeClass('spr' + '-' + theitem + '-back','dimmed');} else {changeClass('spr' + '-' + theitem + '-back','');}
if ((theslot - 1) <= (themax * -1)) {changeClass('spr' + '-' + theitem + '-next','dimmed');} else {changeClass('spr' + '-' + theitem + '-next','');}
